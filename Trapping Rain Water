class Solution:
    def trap(self, height: List[int]) -> int:
        
        total = 0
        left = 0
        right = len(height) - 1
        
        leftMax = 0
        rightMax = 0
        
        while left < right:
            
            if height[left] < height[right]:
                
                if height[left] >= leftMax:
                    leftMax = height[left]
                else:
                    out = leftMax
                    water = out - height[left]
                    total += water
                
                left += 1
            
            else:
                
                if height[right] >= rightMax:
                    rightMax = height[right]
                else:
                    out = rightMax
                    water = out - height[right]
                    total += water
                
                right -= 1
        
        return total
