class Solution:
    def convert(self, s: str, numRows: int) -> str:
        if numRows==1:
            return s
        rows = [''] * min(numRows, len(s))
        row=0
        down=False
        for i in s:
            rows[row] += i
            if row==0 or row==numRows-1:
                down= not down
            if down:
                row+=1
            else:
                row-=1
        return ''.join(rows)
